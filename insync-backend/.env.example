# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL_PARSER=gpt-4o-mini
OPENAI_MODEL_SCORER=gpt-4o
OPENAI_REQUEST_TIMEOUT=60
OPENAI_MAX_CONCURRENCY=20

# LlamaParse
LLAMA_CLOUD_API_KEY=llx-...
LLAMAPARSE_RESULT_TYPE=text
LLAMAPARSE_MODE=premium

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGc...
SUPABASE_ANON_KEY=eyJhbGc...

# Redis (cache + cost telemetry; rate-limit storage is separate below)
REDIS_URL=redis://localhost:6379/0
# Rate-limit storage. "memory://" for single-instance deploys, or a redis URL
# (e.g. "redis://host:6379/1") to share counters across replicas.
RATE_LIMIT_STORAGE=memory://

# CRM integration
CRM_WEBHOOK_URL=https://your-crm.com/webhook/insync
CRM_WEBHOOK_SECRET=your-shared-secret
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Email
RESEND_API_KEY=re_...
EMAIL_FROM=tools@insync.space
EMAIL_FROM_NAME=Insync Recruitment

# App config
FRONTEND_URL=http://localhost:8080
# Comma-separated. Add your production Cloudflare Worker URL once deployed.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:8000
ENVIRONMENT=development
DAILY_COST_ALERT_USD=50
LOG_LEVEL=INFO

# Free tier limits
FREE_TIER_DAILY_RESUME_CAP=100

# Cache TTLs (seconds)
CACHE_TTL_RESULT=3600
CACHE_TTL_FILE_PARSE=86400
CACHE_TTL_JD_PARSE=86400
