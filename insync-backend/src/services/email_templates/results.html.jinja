<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="x-apple-disable-message-reformatting" />
<meta name="color-scheme" content="light" />
<meta name="supported-color-schemes" content="light" />
<title>{{ job_summary.title }} — top candidates from Insync</title>
<style>
  /* Email-client resets */
  body, table, td, p, a, li, h1, h2, h3 { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
  table, td { mso-table-lspace: 0pt; mso-table-rspace: 0pt; border-collapse: collapse; }
  img { -ms-interpolation-mode: bicubic; border: 0; outline: none; text-decoration: none; display: block; }
  a { color: #047857; text-decoration: none; }

  /* Mobile breakpoint */
  @media screen and (max-width: 600px) {
    .container       { width: 100% !important; border-radius: 0 !important; border-left: 0 !important; border-right: 0 !important; }
    .px              { padding-left: 18px !important; padding-right: 18px !important; }
    .title           { font-size: 20px !important; line-height: 1.25 !important; }
    .sub             { font-size: 13px !important; }
    .cand-name       { font-size: 15px !important; }
    .one-line        { font-size: 13px !important; }
    .section-label   { font-size: 11px !important; }
    .bullet          { font-size: 14px !important; line-height: 1.5 !important; }
    .badge-cell      { width: 52px !important; padding-right: 12px !important; }
    .badge           { width: 52px !important; font-size: 17px !important; padding: 8px 0 !important; }
  }
</style>
</head>
<body style="margin:0;padding:0;background:#f5f5f7;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#111827;">

<!-- Inbox preview snippet -->
<div style="display:none;max-height:0;overflow:hidden;mso-hide:all;font-size:1px;line-height:1px;color:#f5f5f7;">
  {{ candidates|length }} candidates ranked for {{ job_summary.title }} — top score {{ candidates[0].score if candidates else "-" }}. Open for strengths, gaps, and interview questions.
</div>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#f5f5f7;">
  <tr>
    <td align="center" style="padding:24px 12px;">

      <table role="presentation" class="container" width="640" cellpadding="0" cellspacing="0" border="0" style="max-width:640px;width:100%;background:#ffffff;border-radius:14px;border:1px solid #e5e7eb;overflow:hidden;">

        <!-- Header -->
        <tr>
          <td class="px" style="padding:24px 28px 18px 28px;border-bottom:1px solid #f1f5f9;">
            <div style="font-size:11px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#047857;">Insync · AI Resume Screener</div>
            <h1 class="title" style="margin:8px 0 4px 0;font-size:22px;font-weight:700;color:#0f172a;line-height:1.2;">
              {{ job_summary.title }}
            </h1>
            <div class="sub" style="font-size:13px;color:#6b7280;line-height:1.5;">
              {{ job_summary.location }}{% if job_summary.company %} &middot; {{ job_summary.company }}{% endif %} &middot;
              {{ candidates|length }} candidate{{ "s" if candidates|length != 1 else "" }} scored
            </div>
          </td>
        </tr>

        {% for c in candidates %}
        <!-- Candidate row -->
        <tr>
          <td class="px" style="padding:18px 28px 6px 28px;{% if not loop.first %}border-top:1px solid #f1f5f9;{% endif %}">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td class="badge-cell" valign="top" width="60" style="width:60px;padding-right:14px;">
                  <div class="badge" style="width:60px;text-align:center;padding:10px 0;border-radius:10px;font-weight:700;font-size:18px;line-height:1;background:{{ band_bg[c.score_band] }};color:{{ band_fg[c.score_band] }};">
                    {{ c.score }}
                  </div>
                </td>
                <td valign="top">
                  <div class="cand-name" style="font-size:15px;font-weight:600;color:#0f172a;line-height:1.3;">
                    {{ loop.index }}. {{ c.name }}
                  </div>
                  <div class="one-line" style="font-size:13px;color:#6b7280;margin-top:3px;line-height:1.45;">
                    {{ c.one_line_summary }}
                  </div>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- Strengths -->
        <tr>
          <td class="px" style="padding:14px 28px 0 28px;">
            <div class="section-label" style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:#047857;margin-bottom:6px;">Strengths</div>
            <ul style="margin:0;padding:0 0 0 20px;color:#1f2937;">
              {% for s in c.strengths %}
              <li class="bullet" style="font-size:14px;line-height:1.5;margin:0 0 4px 0;">{{ s }}</li>
              {% endfor %}
            </ul>
          </td>
        </tr>

        <!-- Gaps -->
        <tr>
          <td class="px" style="padding:14px 28px 0 28px;">
            <div class="section-label" style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:#b45309;margin-bottom:6px;">Gaps</div>
            <ul style="margin:0;padding:0 0 0 20px;color:#1f2937;">
              {% for g in c.gaps %}
              <li class="bullet" style="font-size:14px;line-height:1.5;margin:0 0 4px 0;">{{ g }}</li>
              {% endfor %}
            </ul>
          </td>
        </tr>

        <!-- Interview questions -->
        <tr>
          <td class="px" style="padding:14px 28px 22px 28px;">
            <div class="section-label" style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:#047857;margin-bottom:6px;">Interview questions</div>
            <ol style="margin:0;padding:0 0 0 22px;color:#1f2937;">
              {% for q in c.interview_questions %}
              <li class="bullet" style="font-size:14px;line-height:1.5;margin:0 0 4px 0;">{{ q }}</li>
              {% endfor %}
            </ol>
          </td>
        </tr>
        {% endfor %}

        <!-- Footer -->
        <tr>
          <td class="px" style="padding:18px 28px 22px 28px;border-top:1px solid #f1f5f9;font-size:12px;color:#6b7280;line-height:1.5;">
            Sent by <a href="{{ frontend_url }}" style="color:#047857;text-decoration:none;font-weight:600;">Insync AI Resume Screener</a>
            &middot; session {{ session_id[:8] }}{% if metadata %} &middot; scored in {{ (metadata.processing_time_ms / 1000) | round(1) }}s{% endif %}
          </td>
        </tr>
      </table>

      <div style="max-width:640px;margin:16px auto 0 auto;padding:0 8px;font-size:11px;color:#9ca3af;text-align:center;line-height:1.5;">
        You're receiving this because you used Insync's AI Resume Screener.
        Resumes are never stored after scoring.
      </div>

    </td>
  </tr>
</table>

</body>
</html>
